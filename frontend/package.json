{
	"name": "memory-palace",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "oxlint . && biome check .",
		"lint:fix": "oxlint --fix . && biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"check": "npm run format && npm run lint && npm run typecheck && npm run test && npm run build"
	},
	"dependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.2.7",
		"recharts": "^3.8.1",
		"three": "^0.185.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.0.0",
		"@types/three": "^0.185.0",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/coverage-v8": "^4.1.6",
		"jsdom": "^29.1.1",
		"oxlint": "^1.71.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}

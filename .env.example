# Database
DATABASE_URL=postgresql://memory_palace:password@localhost:5432/memory_palace

# Authentication
JWT_SECRET=  # Required. Secret key for JWT token signing (min 32 chars). Generate with: openssl rand -hex 32
JWT_EXPIRE_MINUTES=60  # Optional. Access token lifetime in minutes (default: 60)

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173
